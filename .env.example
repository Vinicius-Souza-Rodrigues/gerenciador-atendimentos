# Copie para .env e preencha. O .env NUNCA deve ser commitado.

# --- PostgreSQL ---
POSTGRES_DB=agendamentos
POSTGRES_USER=agendamentos
POSTGRES_PASSWORD=troque-esta-senha

# --- Telegram (Modelo A: 1 bot da plataforma) ---
TELEGRAM_BOT_TOKEN=coloque-o-token-do-BotFather
TELEGRAM_BOT_USERNAME=SeuBot

# --- Autenticação ---
# Segredo longo e aleatório para assinar os JWT (ex.: openssl rand -base64 48)
JWT_SECRET=troque-por-um-segredo-longo-aleatorio

# --- Fuso horário (fixo no MVP) ---
TZ=America/Sao_Paulo
